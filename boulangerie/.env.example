# --- Base de données PostgreSQL (Supabase) ---
# DATABASE_URL : connexion runtime. En production sur Vercel, utilisez le POOLER
#   Supabase (Transaction, port 6543) avec ?pgbouncer=true.
# DIRECT_URL   : connexion directe (port 5432), utilisée pour les migrations.
# Les deux se trouvent dans Supabase → Project Settings → Database.
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Secret de signature des cookies de session du back-office (chaîne aléatoire longue).
SESSION_SECRET="changez-moi-pour-un-secret-long-et-aleatoire"

# Mot de passe initial du back-office (utilisé uniquement au seed).
ADMIN_PASSWORD="maison2026"

# --- Supabase Storage (upload des photos produits) ---
# SUPABASE_URL : https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY : Supabase → Project Settings → API → service_role (secret).
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
