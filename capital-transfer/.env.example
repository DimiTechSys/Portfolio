# Copie ce fichier vers `.env` ou `.env.local` puis remplace les valeurs.
# Ne commite jamais `.env` / `.env.local` (secrets).

# --- Base de données (Prisma, migrations, dédup e-mail checkout) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# --- Stripe (paiement Checkout + API) ---
# Dashboard : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhooks : https://dashboard.stripe.com/webhooks — événement checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# --- Resend (e-mails de confirmation réservation) ---
# Dashboard : https://resend.com/api-keys
RESEND_API_KEY=
# Domaine vérifié chez Resend, ex. : Capitale Transfer <noreply@tondomaine.com>
# En test uniquement tu peux utiliser : Capitale Transfer <onboarding@resend.dev>
RESEND_FROM_EMAIL=
